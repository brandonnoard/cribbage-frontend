# Auth0 — use the League Manager SPA client from cribbage-infra/auth0/client.tf
# No inline comments on the same line (Vite/dotenv can misparse them).
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://noard.org/cribbage/

# Public URL path prefix when not served from web root (optional; defaults to /)
VITE_BASE_PATH=/cribbage

# API Gateway invoke URL for dev (no trailing slash)
# aws ssm get-parameter --name /cribbage/dev/api-gateway/invoke-url --query Parameter.Value --output text
VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/dev
